    justify-content: center;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }
  .loading-screen.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .loading-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .loading-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--white);
  }
  .loading-bar {
    width: 160px;
    height: 2px;
    background: var(--gray-700);
