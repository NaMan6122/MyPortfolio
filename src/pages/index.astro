      </div>
      <div class="terminal-body" id="terminalBody">
        <div class="terminal-line-output">Type <span class="terminal-highlight">help</span> to see available commands.</div>
      </div>
      <div class="terminal-input-line">
        <span class="terminal-prompt">$</span>
        <input type="text" class="terminal-input" id="terminalInput" autocomplete="off" spellcheck="false" placeholder="enter a command..." />
      </div>
    </div>
  </div>

  <script>
    // Import Three.js
    import * as THREE from 'three';

    // ========== LOADING SCREEN ==========
    const loadingScreen = document.getElementById('loadingScreen')!;
    const loadingFill = loadingScreen.querySelector('.loading-fill') as HTMLElement;
    let loadProgress = 0;
    const loadInterval = setInterval(() => {
      loadProgress += Math.random() * 15 + 5;
      if (loadProgress >= 100) {
        loadProgress = 100;
        loadingFill.style.width = '100%';
        clearInterval(loadInterval);
        setTimeout(() => loadingScreen.classList.add('hidden'), 200);
        setTimeout(() => loadingScreen.remove(), 700);
      } else {
        loadingFill.style.width = loadProgress + '%';
      }
    }, 100);

    // ========== SOUND EFFECTS ==========
    const SoundFX = (() => {
      let ctx: AudioContext | null = null;
      const getCtx = () => {
        if (!ctx) {
          const AudioCtx = window.AudioContext || (window as any).webkitAudioContext;
          if (AudioCtx) ctx = new AudioCtx();
        }
        return ctx;
      };

      const playTone = (freq: number, type: OscillatorType, attack: number, decay: number, vol: number) => {
        const c = getCtx();
        if (!c) return;
        const osc = c.createOscillator();
        const gain = c.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, c.currentTime);
        gain.gain.setValueAtTime(0, c.currentTime);
        gain.gain.linearRampToValueAtTime(vol, c.currentTime + attack);
        gain.gain.exponentialRampToValueAtTime(0.001, c.currentTime + attack + decay);
        osc.connect(gain).connect(c.destination);
        osc.start(c.currentTime);
        osc.stop(c.currentTime + attack + decay);
      };

      const playNoise = (filterFreq: number, q: number, attack: number, decay: number, vol: number) => {
        const c = getCtx();
        if (!c) return;
        const bufferSize = c.sampleRate * 0.1;
        const buffer = c.createBuffer(1, bufferSize, c.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
        const source = c.createBufferSource();
        source.buffer = buffer;
        const filter = c.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.setValueAtTime(filterFreq, c.currentTime);
        filter.Q.setValueAtTime(q, c.currentTime);
        const gain = c.createGain();
        gain.gain.setValueAtTime(0, c.currentTime);
        gain.gain.linearRampToValueAtTime(vol, c.currentTime + attack);
        gain.gain.exponentialRampToValueAtTime(0.001, c.currentTime + attack + decay);
        source.connect(filter).connect(gain).connect(c.destination);
        source.start(c.currentTime);
      };

      const sounds: Record<string, () => void> = {
        tick: () => {
          playTone(800, 'sine', 0.005, 0.06, 0.08);
          playNoise(2000, 2, 0.003, 0.04, 0.03);
        },
        toggle: () => {
          playTone(600, 'sine', 0.01, 0.08, 0.1);
          setTimeout(() => playTone(900, 'sine', 0.01, 0.06, 0.08), 60);
        },
        press: () => {
          playTone(400, 'square', 0.005, 0.05, 0.06);
          playNoise(1500, 3, 0.002, 0.03, 0.04);
        },
        release: () => {
          playTone(500, 'sine', 0.005, 0.04, 0.05);
        },
        whoosh: () => {
          playNoise(800, 1, 0.02, 0.2, 0.06);
        }
      };

      return {
        play: (name: string) => sounds[name]?.()
      };
    })();

    // Bind hover sounds
    document.querySelectorAll('[data-hover-sound]').forEach(el => {
      el.addEventListener('mouseenter', () => SoundFX.play(el.getAttribute('data-hover-sound') || 'tick'));
    });

    // ========== PROJECT PREVIEW ==========
    const preview = document.getElementById('projectPreview')!;
    const previewIframe = document.getElementById('previewIframe') as HTMLIFrameElement;
    const previewUrl = document.getElementById('previewUrl')!;
    const previewName = document.getElementById('previewName')!;
    let previewTimeout: ReturnType<typeof setTimeout>;
    let scrollInterval: ReturnType<typeof setInterval>;
    let currentPreviewUrl = '';

    document.querySelectorAll('.project-row').forEach(row => {
      row.addEventListener('mouseenter', (e: any) => {
        const href = row.getAttribute('href');
        const name = row.querySelector('.project-name')?.textContent;
        if (!href) return;

        // Set preview content
        previewUrl.textContent = new URL(href).hostname;
        previewName.textContent = `Preview: ${name}`;

        // Position preview near cursor
        const rect = row.getBoundingClientRect();
        let left = rect.right + 16;
        let top = rect.top;

        // Keep within viewport
        if (left + 480 > window.innerWidth) {
          left = rect.left - 496;
        }
        if (top + 340 > window.innerHeight) {
          top = window.innerHeight - 350;
        }
        if (top < 10) top = 10;

        preview.style.left = left + 'px';
        preview.style.top = top + 'px';

        // Load iframe after delay
        previewTimeout = setTimeout(() => {
          if (currentPreviewUrl !== href) {
            previewIframe.src = href;
            currentPreviewUrl = href;
          }
          preview.classList.add('visible');

          // Auto-scroll the iframe
          clearInterval(scrollInterval);
          scrollInterval = setInterval(() => {
            try {
              const iframeDoc = previewIframe.contentDocument || previewIframe.contentWindow?.document;
              if (iframeDoc) {
                const maxScroll = iframeDoc.documentElement.scrollHeight - iframeDoc.documentElement.clientHeight;
                if (iframeDoc.documentElement.scrollTop >= maxScroll) {
                  iframeDoc.documentElement.scrollTop = 0;
                } else {
                  iframeDoc.documentElement.scrollTop += 1;
                }
              }
            } catch (e) {
              // Cross-origin - can't scroll
            }
          }, 50);
        }, 400);
      });

      row.addEventListener('mouseleave', () => {
        clearTimeout(previewTimeout);
        clearInterval(scrollInterval);
        preview.classList.remove('visible');
      });
    });

    // ========== CUSTOM CURSOR ==========
    const cursorDot = document.getElementById('cursorDot')!;
    const cursorRing = document.getElementById('cursorRing')!;
    let mouseX = 0, mouseY = 0;
    let ringX = 0, ringY = 0;

    document.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursorDot.style.left = mouseX - 4 + 'px';
      cursorDot.style.top = mouseY - 4 + 'px';
    });

    const animateCursor = () => {
      ringX += (mouseX - ringX) * 0.15;
      ringY += (mouseY - ringY) * 0.15;
      cursorRing.style.left = ringX - 18 + 'px';
      cursorRing.style.top = ringY - 18 + 'px';
      requestAnimationFrame(animateCursor);
    };
    animateCursor();

    document.querySelectorAll('a, button, .project-row, .social-item, .cta-btn').forEach(el => {
      el.addEventListener('mouseenter', () => cursorRing.classList.add('hovering'));
      el.addEventListener('mouseleave', () => cursorRing.classList.remove('hovering'));
    });

    // ========== CARD TILT ==========
    document.querySelectorAll('.card').forEach(card => {
      card.addEventListener('mousemove', (e: any) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const tiltX = (y - centerY) / centerY * -3;
        const tiltY = (x - centerX) / centerX * 3;
        card.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
        (card as HTMLElement).style.setProperty('--mouse-x', x + 'px');
        (card as HTMLElement).style.setProperty('--mouse-y', y + 'px');
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });

    // ========== SCROLL ANIMATIONS ==========
    const animObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          animObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.anim').forEach(el => animObserver.observe(el));

    // ========== STAT COUNTERS ==========
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.count || '0', 10);
          const duration = 1200;
          const start = performance.now();
          const animate = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(eased * target));
            if (progress < 1) requestAnimationFrame(animate);
          };
          requestAnimationFrame(animate);
          counterObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.stat-number[data-count]').forEach(el => counterObserver.observe(el));

    // ========== GITHUB DATA FETCHING ==========
    async function fetchGitHubData() {
      const cacheKey = 'portfolio-github-data';
      const cached = localStorage.getItem(cacheKey);
      const cacheTime = localStorage.getItem(cacheKey + '-time');
      const oneDay = 24 * 60 * 60 * 1000;

      if (cached && cacheTime && (Date.now() - parseInt(cacheTime)) < oneDay) {
        return JSON.parse(cached);
      }

      try {
        const [contribRes, pinnedRes] = await Promise.all([
          fetch('/data/contributions.json'),
          fetch('/data/pinned.json')
        ]);
        const data = {
          contributions: await contribRes.json(),
          pinned: await pinnedRes.json()
        };
        localStorage.setItem(cacheKey, JSON.stringify(data));
        localStorage.setItem(cacheKey + '-time', String(Date.now()));
        return data;
      } catch (e) {
        if (cached) return JSON.parse(cached);
        return { contributions: { weeks: [], totalContributions: 0, currentStreak: 0, longestStreak: 0 }, pinned: [] };
      }
    }

    // ========== HEATMAP ==========
    async function renderHeatmap() {
      const data = await fetchGitHubData();
      const grid = document.getElementById('heatmapGrid')!;
      const totalEl = document.getElementById('heatmapTotal')!;
      const weeks = data.contributions.weeks;

      grid.innerHTML = '';

      if (weeks.length === 0) {
        totalEl.textContent = 'No contribution data yet';
        return;
      }

      // Build 7 rows × 52 cols grid
      const allDays: { date: string; count: number }[] = [];
      for (const week of weeks) {
        for (const day of week.contributionDays) {
          allDays.push({ date: day.date, count: day.contributionCount });
        }
      }

      // Pad start if needed (first week might not start on Sunday)
      const firstDate = new Date(allDays[0]?.date || Date.now());
      const startDow = firstDate.getDay();
      for (let i = 0; i < startDow; i++) {
        const cell = document.createElement('div');
        cell.className = 'heatmap-cell level-0';
        grid.appendChild(cell);
      }

      for (const day of allDays) {
        const cell = document.createElement('div');
        const level = day.count === 0 ? 0 : day.count <= 3 ? 1 : day.count <= 6 ? 2 : day.count <= 9 ? 3 : 4;
        cell.className = `heatmap-cell level-${level}`;
        const dateObj = new Date(day.date);
        const formatted = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        cell.setAttribute('data-tooltip', `${day.count} contributions on ${formatted}`);
        grid.appendChild(cell);
      }

      totalEl.textContent = `${data.contributions.totalContributions} contributions in the last year`;
    }

    // ========== PINNED REPOS ==========
    async function renderPinnedRepos() {
      const data = await fetchGitHubData();
      const grid = document.getElementById('pinnedGrid')!;

      if (!data.pinned || data.pinned.length === 0) {
        grid.innerHTML = '<div class="pinned-loading">No pinned repos available</div>';
        return;
      }

      grid.innerHTML = data.pinned.map((repo: any) => `
        <a href="${repo.url}" target="_blank" class="pinned-repo" data-hover-sound="tick">
          <div class="pinned-repo-name">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            ${repo.name}
          </div>
          <div class="pinned-repo-desc">${repo.description || 'No description'}</div>
          <div class="pinned-repo-meta">
            ${repo.language ? `<span><span class="pinned-lang-dot" style="background:${repo.language.color}"></span> ${repo.language.name}</span>` : ''}
            <span>★ ${repo.stars}</span>
            <span>⑂ ${repo.forks}</span>
          </div>
        </a>
      `).join('');

      // Rebind hover sounds for new elements
      grid.querySelectorAll('[data-hover-sound]').forEach(el => {
        el.addEventListener('mouseenter', () => SoundFX.play(el.getAttribute('data-hover-sound') || 'tick'));
      });
    }

    // ========== STREAK WIDGET ==========
    async function renderStreak() {
      const data = await fetchGitHubData();
      const c = data.contributions;

      const streakObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateValue('currentStreak', c.currentStreak);
            animateValue('longestStreak', c.longestStreak);
            animateValue('totalContributions', c.totalContributions);
            streakObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });

      function animateValue(id: string, target: number) {
        const el = document.getElementById(id);
        if (!el) return;
        const duration = 1000;
        const start = performance.now();
        const animate = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = String(Math.round(eased * target));
          if (progress < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
      }

      const streakEl = document.querySelector('.card-streak');
      if (streakEl) streakObserver.observe(streakEl);
    }

    // ========== TIMEZONE CLOCK ==========
    function updateClock() {
      const now = new Date();
      const time = now.toLocaleTimeString('en-US', { hour12: false });
      const zone = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const offset = -(now.getTimezoneOffset() / 60);
      const sign = offset >= 0 ? '+' : '';
      const hour = now.getHours();

      document.getElementById('tzClock')!.textContent = time;
      document.getElementById('tzZone')!.textContent = zone;
      document.getElementById('tzOffset')!.textContent = `UTC${sign}${offset}`;

      const available = hour >= 9 && hour < 18;
      const availEl = document.getElementById('tzAvailability')!;
      availEl.innerHTML = available
        ? '<span class="tz-dot available"></span><span>Available for work</span>'
        : '<span class="tz-dot unavailable"></span><span>Currently offline</span>';
    }
    updateClock();
    setInterval(updateClock, 1000);

    // ========== INTERACTIVE TERMINAL ==========
    const terminalCommands: Record<string, string> = {
      help: `Available commands:
  help     — Show this message
  about    — About Naman
  projects — List of projects
  skills   — Technical skills
  contact  — Contact information
  clear    — Clear the terminal`,
      about: 'Naman Gupta — Software Engineer at Siemens & indie builder. Obsessed with making AI tools that remember. Building Anvaya, an AI coding assistant with self-learning memory.',
      projects: `Live projects:
  • Anvaya — AI coding assistant with self-learning memory
  • QuantaLLM — On-device LLM inference for Android
  • Helmsman — Control your Mac from your phone

In development:
  • Weave — AI-native backlink exchange via MCP
  • LaunchRelay — Reciprocal traffic for indie founders
  • Noema — Experimental Rust project`,
      skills: 'Rust, Go, TypeScript, Kotlin, Java, C++, Python, React, Node.js, SQLite, PostgreSQL, Docker, Linux, Git',
      contact: `Email: namang2510@gmail.com
X/Twitter: @HyveMindx1
GitHub: github.com/NaMan6122
LinkedIn: namangupta2510`
    };

    const terminalBody = document.getElementById('terminalBody')!;
    const terminalInput = document.getElementById('terminalInput') as HTMLInputElement;
    const commandHistory: string[] = [];
    let historyIndex = -1;

    terminalInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const cmd = terminalInput.value.trim().toLowerCase();
        if (!cmd) return;

        commandHistory.push(cmd);
        historyIndex = commandHistory.length;

        // Add command line
        const cmdLine = document.createElement('div');
        cmdLine.className = 'terminal-cmd-line';
        cmdLine.innerHTML = `<span class="terminal-prompt">$</span> ${cmd}`;
        terminalBody.appendChild(cmdLine);

        // Process command
        if (cmd === 'clear') {
          terminalBody.innerHTML = '';
        } else if (terminalCommands[cmd]) {
          const response = document.createElement('div');
          response.className = 'terminal-response';
          response.textContent = terminalCommands[cmd];
          terminalBody.appendChild(response);
        } else {
          const error = document.createElement('div');
          error.className = 'terminal-error';
          error.textContent = `command not found: ${cmd}. Type 'help' for available commands.`;
          terminalBody.appendChild(error);
        }

        terminalInput.value = '';
        terminalBody.scrollTop = terminalBody.scrollHeight;
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          terminalInput.value = commandHistory[historyIndex];
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          terminalInput.value = commandHistory[historyIndex];
        } else {
          historyIndex = commandHistory.length;
          terminalInput.value = '';
        }
      }
    });

    // Click terminal to focus input
    document.querySelector('.card-terminal')?.addEventListener('click', () => {
      terminalInput?.focus();
    });

    // Initialize all new features
    renderHeatmap();
    renderPinnedRepos();
    renderStreak();

    // ========== SCROLL PROGRESS ==========
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? (scrolled / total) * 100 : 0;
      document.getElementById('scrollProgress')!.style.width = pct + '%';
    });

    // ========== THREE.JS BACKGROUNDS ==========
    const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 5;

    let currentBg: THREE.Object3D | null = null;
    let currentAnimate: ((time: number) => void) | null = null;

    // Background: Particles
    function createParticles() {
      const group = new THREE.Group();
      const count = 2000;
      const geometry = new THREE.BufferGeometry();
      const positions = new Float32Array(count * 3);
      const colors = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        positions[i * 3] = (Math.random() - 0.5) * 20;
        positions[i * 3 + 1] = (Math.random() - 0.5) * 20;
        positions[i * 3 + 2] = (Math.random() - 0.5) * 20;
        const c = 0.5 + Math.random() * 0.5;
        colors[i * 3] = c;
        colors[i * 3 + 1] = c;
        colors[i * 3 + 2] = c;
      }
      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
      const material = new THREE.PointsMaterial({ size: 0.04, vertexColors: true, transparent: true, opacity: 0.9 });
      const points = new THREE.Points(geometry, material);
      group.add(points);
      scene.add(group);

      return {
        obj: group,
        animate: (time: number) => {
          points.rotation.y = time * 0.05;
          points.rotation.x = Math.sin(time * 0.03) * 0.1;
          // Mouse interaction
          const posAttr = geometry.getAttribute('position') as THREE.BufferAttribute;
          for (let i = 0; i < count; i++) {
            const ix = i * 3 + 1;
            posAttr.array[ix] += Math.sin(time * 0.5 + i * 0.1) * 0.0005;
          }
          posAttr.needsUpdate = true;
        }
      };
    }

    // Background: Waves
    function createWaves() {
      const group = new THREE.Group();
      const planeGeo = new THREE.PlaneGeometry(30, 30, 80, 80);
      const planeMat = new THREE.MeshBasicMaterial({ color: 0x444444, wireframe: true, transparent: true, opacity: 0.5 });
      const plane = new THREE.Mesh(planeGeo, planeMat);
      plane.rotation.x = -Math.PI / 2.5;
      group.add(plane);
      scene.add(group);

      return {
        obj: group,
        animate: (time: number) => {
          const pos = planeGeo.getAttribute('position') as THREE.BufferAttribute;
          for (let i = 0; i < pos.count; i++) {
            const x = pos.getX(i);
            const y = pos.getY(i);
            pos.setZ(i, Math.sin(x * 0.3 + time) * 0.5 + Math.cos(y * 0.3 + time * 0.7) * 0.5);
          }
          pos.needsUpdate = true;
          plane.rotation.z = time * 0.02;
        }
      };
    }

    // Background: Stars
    function createStars() {
      const group = new THREE.Group();
      const count = 3000;
      const geometry = new THREE.BufferGeometry();
      const positions = new Float32Array(count * 3);
      const sizes = new Float32Array(count);
      for (let i = 0; i < count; i++) {
        positions[i * 3] = (Math.random() - 0.5) * 50;
        positions[i * 3 + 1] = (Math.random() - 0.5) * 50;
        positions[i * 3 + 2] = (Math.random() - 0.5) * 50;
        sizes[i] = Math.random() * 2 + 0.5;
      }
      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
      const material = new THREE.PointsMaterial({ size: 0.08, color: 0xffffff, transparent: true, opacity: 1.0 });
      const stars = new THREE.Points(geometry, material);
      group.add(stars);

      // Nebula cloud
      const nebulaGeo = new THREE.SphereGeometry(8, 32, 32);
      const nebulaMat = new THREE.MeshBasicMaterial({ color: 0x2a2a4e, transparent: true, opacity: 0.15 });
      const nebula = new THREE.Mesh(nebulaGeo, nebulaMat);
      group.add(nebula);

      scene.add(group);

      return {
        obj: group,
        animate: (time: number) => {
          stars.rotation.y = time * 0.02;
          stars.rotation.x = time * 0.01;
          nebula.rotation.z = time * 0.005;
        }
      };
    }

    // Background: Geometry
    function createGeometry() {
      const group = new THREE.Group();
      const shapes: THREE.Mesh[] = [];

      for (let i = 0; i < 8; i++) {
        let geo: THREE.BufferGeometry;
        const r = Math.random();
        if (r < 0.33) geo = new THREE.OctahedronGeometry(0.3 + Math.random() * 0.5, 0);
        else if (r < 0.66) geo = new THREE.TetrahedronGeometry(0.3 + Math.random() * 0.5, 0);
        else geo = new THREE.IcosahedronGeometry(0.3 + Math.random() * 0.5, 0);

        const edges = new THREE.EdgesGeometry(geo);
        const lineMat = new THREE.LineBasicMaterial({ color: 0x666666, transparent: true, opacity: 0.7 });
        const wireframe = new THREE.LineSegments(edges, lineMat);
        wireframe.position.set((Math.random() - 0.5) * 8, (Math.random() - 0.5) * 8, (Math.random() - 0.5) * 8);
        shapes.push(wireframe);
        group.add(wireframe);
      }

      // Connecting lines
      const lineGeo = new THREE.BufferGeometry();
      const linePositions = new Float32Array(100 * 6);
      for (let i = 0; i < 100; i++) {
        const a = shapes[Math.floor(Math.random() * shapes.length)].position;
        const b = shapes[Math.floor(Math.random() * shapes.length)].position;
        linePositions[i * 6] = a.x;
        linePositions[i * 6 + 1] = a.y;
        linePositions[i * 6 + 2] = a.z;
        linePositions[i * 6 + 3] = b.x;
        linePositions[i * 6 + 4] = b.y;
        linePositions[i * 6 + 5] = b.z;
      }
      lineGeo.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
      const linesMat = new THREE.LineBasicMaterial({ color: 0x555555, transparent: true, opacity: 0.4 });
      const lines = new THREE.LineSegments(lineGeo, linesMat);
      group.add(lines);

      scene.add(group);

      return {
        obj: group,
        animate: (time: number) => {
          shapes.forEach((s, i) => {
            s.rotation.x = time * 0.1 * (i % 2 === 0 ? 1 : -1);
            s.rotation.y = time * 0.08 * (i % 3 === 0 ? 1 : -1);
          });
        }
      };
    }

    // Background: Matrix
    function createMatrix() {
      const group = new THREE.Group();
      const columns = 40;
      const rows = 30;
      const geometry = new THREE.PlaneGeometry(0.3, 0.3);
      const meshes: THREE.Mesh[] = [];
      const speeds: number[] = [];

      for (let x = 0; x < columns; x++) {
        for (let y = 0; y < rows; y++) {
          const brightness = Math.random() * 0.3;
          const mat = new THREE.MeshBasicMaterial({ color: new THREE.Color(brightness, brightness * 1.3, brightness), transparent: true, opacity: 0.6 });
          const mesh = new THREE.Mesh(geometry, mat);
          mesh.position.set((x - columns / 2) * 0.5, (y - rows / 2) * 0.5, 0);
          meshes.push(mesh);
          speeds.push(Math.random() * 2 + 0.5);
          group.add(mesh);
        }
      }

      scene.add(group);

      return {
        obj: group,
        animate: (time: number) => {
          meshes.forEach((m, i) => {
            const pulse = Math.sin(time * speeds[i] + i * 0.5) * 0.5 + 0.5;
            (m.material as THREE.MeshBasicMaterial).opacity = pulse * 0.8;
            const brightness = 0.1 + pulse * 0.3;
            (m.material as THREE.MeshBasicMaterial).color.setRGB(brightness, brightness * 1.2, brightness);
          });
        }
      };
    }

    // Switch backgrounds
    const backgrounds: Record<string, () => { obj: THREE.Object3D; animate: (t: number) => void }> = {
      particles: createParticles,
      waves: createWaves,
      stars: createStars,
      geometry: createGeometry,
      matrix: createMatrix
    };

    function switchBg(name: string) {
      if (currentBg) {
        scene.remove(currentBg);
      }
      const creator = backgrounds[name];
      if (creator) {
        const bg = creator();
        currentBg = bg.obj;
        currentAnimate = bg.animate;
      }
    }

    switchBg('particles');

    // Restore saved background theme
    const savedBg = localStorage.getItem('portfolio-bg');
    if (savedBg && backgrounds[savedBg]) {
      switchBg(savedBg);
      document.querySelectorAll('.bg-btn').forEach(b => b.classList.remove('active'));
      document.querySelector(`[data-bg="${savedBg}"]`)?.classList.add('active');
    }

    // Background switcher buttons
    document.querySelectorAll('.bg-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.bg-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const bgName = btn.getAttribute('data-bg')!;
        switchBg(bgName);
        localStorage.setItem('portfolio-bg', bgName);
        SoundFX.play('whoosh');
      });
    });

    // Mouse tracking for parallax
    let mouseXNorm = 0, mouseYNorm = 0;
    document.addEventListener('mousemove', e => {
      mouseXNorm = (e.clientX / window.innerWidth) * 2 - 1;
      mouseYNorm = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    // Animation loop
    function animate(time: number) {
      requestAnimationFrame(animate);
      const t = time * 0.001;
      camera.position.x += (mouseXNorm * 0.5 - camera.position.x) * 0.02;
      camera.position.y += (mouseYNorm * 0.5 - camera.position.y) * 0.02;
      camera.lookAt(scene.position);
      if (currentAnimate) currentAnimate(t);
      renderer.render(scene, camera);
    }
    animate(0);

    // Resize
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  </script>
</Layout>

