    overflow: hidden;
  }
  .loading-fill {
    width: 0%;
    height: 100%;
    background: var(--white);
    border-radius: 2px;
    transition: width 0.3s ease;
  }
  .loading-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gray-500);
  }

  /* Background Canvas */
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* Cursor */
  .cursor-dot {
    width: 8px;
    height: 8px;
    background: var(--white);
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
  }
  .cursor-ring {
    width: 36px;
    height: 36px;
    border: 1.5px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9998;
    transition: width 0.2s, height 0.2s, border-color 0.2s;
  }
  .cursor-ring.hovering {
    width: 52px;
    height: 52px;
    border-color: rgba(255,255,255,0.6);
  }

  /* Scroll Progress */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, #666, #fff);
    z-index: 10000;
  }

  /* Background Switcher */
  .bg-switcher {
    position: fixed;
    top: 20px;
    right: 20px;
    display: flex;
    gap: 6px;
    z-index: 10001;
    background: rgba(10, 10, 10, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 6px;
  }
  .bg-btn {
    width: 32px;
    height: 32px;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--gray-500);
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .bg-btn:hover {
    color: var(--white);
    background: var(--surface-hover);
  }
  .bg-btn.active {
    color: var(--white);
    border-color: var(--border-hover);
    background: var(--surface-hover);
  }

  /* Project Preview Tooltip */
  .project-preview {
    position: fixed;
    width: 480px;
    height: 340px;
    pointer-events: none;
    z-index: 15000;
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    transition: opacity 0.25s ease, transform 0.25s ease;
    filter: drop-shadow(0 24px 80px rgba(0,0,0,0.7));
  }
  .project-preview.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .project-preview-window {
    width: 100%;
    height: 100%;
    background: var(--surface);
    border: 1px solid var(--border-hover);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .preview-titlebar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .preview-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .preview-dot.r { background: #ff5f57; }
  .preview-dot.y { background: #febc2e; }
  .preview-dot.g { background: #28c840; }
  .preview-dot.green { background: #22c55e; width: 5px; height: 5px; }
  .preview-url {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--gray-500);
    margin-left: 8px;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .preview-viewport {
    flex: 1;
    overflow: hidden;
    position: relative;
    background: #fff;
  }
  .preview-viewport iframe {
    width: 200%;
    height: 200%;
    border: none;
    transform: scale(0.5);
    transform-origin: top left;
    pointer-events: none;
  }
  .preview-label {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--gray-300);
    margin-top: -30px;
    position: relative;
    z-index: 1;
    border-radius: 0 0 10px 10px;
  }

  /* Layout */
  .wrapper {
    min-height: 100dvh;
    padding: var(--gap);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
    grid-template-rows: auto auto auto auto;
    grid-template-areas:
      "profile    about       about       works       works"
      "heatmap    pinned      pinned      works       works"
      "tech       activity    social      social      streak"
      "terminal   terminal    timezone    timezone    cta";
    gap: var(--gap);
    position: relative;
    z-index: 1;
    align-content: start;
  }

  /* Card Base */
  .card {
    background: rgba(10, 10, 10, 0.45);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .card:hover {
    border-color: rgba(255, 255, 255, 0.12);
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
    pointer-events: none;
  }
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.03), transparent 40%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .card:hover::after {
    opacity: 1;
  }

  /* Card Labels */
  .card-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-500);
    margin-bottom: 16px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .label-dot {
    width: 5px;
    height: 5px;
    background: var(--gray-700);
    border-radius: 50%;
  }

  /* Intro Card */
  .card-intro { grid-area: profile; justify-content: space-between; min-height: 0; overflow: visible; }
  .intro-name { font-size: clamp(28px, 3vw, 40px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 12px; }
  .intro-role { font-size: clamp(13px, 1.2vw, 15px); color: var(--gray-300); font-weight: 400; line-height: 1.5; }
  .intro-status { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--gray-500); margin-top: auto; }
  .status-dot { width: 7px; height: 7px; background: #22c55e; border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 4px rgba(34,197,94,0); }
  }
  .terminal-line {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gray-500);
    margin-top: 14px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .terminal-prompt { color: #22c55e; }
  .terminal-cursor {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: var(--white);
    animation: blink 1s step-end infinite;
    vertical-align: middle;
  }
  @keyframes blink { 50% { opacity: 0; } }
  .terminal-text { overflow: hidden; white-space: nowrap; }
  .terminal-text.typing { animation: typeIn 2s steps(40, end) forwards; width: 0; }
  @keyframes typeIn { from { width: 0; } to { width: 100%; } }

  /* About Card */
  .card-about { grid-area: about; overflow-y: auto; scrollbar-width: none; min-height: 0; }
  .card-about::-webkit-scrollbar { display: none; }
  .about-text { font-size: 13px; color: var(--gray-300); line-height: 1.65; margin-bottom: 12px; }
  .about-text:last-child { margin-bottom: 0; }
  .about-text strong { color: var(--white); font-weight: 500; }
  .github-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 14px; }
  .stat-box {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 12px;
    text-align: center;
  }
  .stat-number { font-size: 20px; font-weight: 700; color: var(--white); font-family: 'JetBrains Mono', monospace; line-height: 1; }
  .stat-label { font-size: 9px; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }

  /* Projects Card */
  .card-projects { grid-area: works; padding: 20px; min-height: 0; }
  .projects-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; flex-shrink: 0; }
  .projects-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-500);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .projects-count { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--gray-700); }
  .projects-list { flex: 1; display: flex; flex-direction: column; gap: 4px; overflow-y: auto; scrollbar-width: none; }
  .projects-list::-webkit-scrollbar { display: none; }
  .project-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--white);
    transition: background 0.2s ease;
    cursor: pointer;
    min-height: 42px;
  }
  .project-row:hover { background: var(--surface-hover); }
  .project-row:hover .project-arrow { opacity: 1; transform: translateX(0); }
  .project-row:hover .project-name { color: var(--white); }
  .project-name { font-size: 14px; font-weight: 500; letter-spacing: -0.01em; color: var(--gray-100); transition: color 0.2s ease; }
  .project-desc { font-size: 12px; color: var(--gray-500); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
  .project-tags { display: flex; gap: 5px; }
  .project-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--gray-500);
    white-space: nowrap;
  }
  .project-arrow { font-size: 13px; color: var(--gray-500); opacity: 0; transform: translateX(-4px); transition: all 0.2s ease; }
  .project-status { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .project-status.live { background: #22c55e; }
  .project-status.dev { background: #eab308; }

  /* Tech Stack */
  .card-tech { grid-area: tech; min-height: 0; }
  .tech-grid { display: flex; flex-wrap: wrap; gap: 6px; align-content: flex-start; overflow-y: auto; scrollbar-width: none; }
  .tech-grid::-webkit-scrollbar { display: none; }
  .tech-pill {
    padding: 6px 11px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 7px;
    font-size: 12px;
    font-weight: 500;
    color: var(--gray-300);
    transition: all 0.2s ease;
    cursor: default;
  }
  .tech-pill:hover { border-color: var(--gray-500); color: var(--white); transform: translateY(-1px); }
  .tech-pill.primary { background: rgba(255,255,255,0.08); border-color: var(--gray-700); color: var(--white); }

  /* Activity Card */
  .card-now { grid-area: activity; overflow: visible; min-height: 0; }
  .card-now .card-label { flex-shrink: 0; }
  .card-now-scroll { flex: 1; overflow-y: auto; scrollbar-width: none; min-height: 0; }
  .card-now-scroll::-webkit-scrollbar { display: none; }
  .now-section { margin-bottom: 12px; }
  .now-section:last-child { margin-bottom: 0; }
  .now-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--gray-700); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
  .now-item { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; background: rgba(255,255,255,0.02); border: 1px solid var(--border); }
  .now-icon { font-size: 18px; flex-shrink: 0; }
  .now-info { flex: 1; min-width: 0; }
  .now-title { font-size: 12px; font-weight: 500; color: var(--gray-100); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .now-meta { font-size: 10px; color: var(--gray-500); }

  /* Social Card */
  .card-social { grid-area: social; min-height: 0; }
  .social-list { display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .social-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 12px;
    height: 44px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--white);
    transition: background 0.2s ease;
    font-size: 13px;
  }
  .social-item:hover { background: var(--surface-hover); }
  .social-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 14px;
  }
  .social-info { flex: 1; min-width: 0; }
  .social-name { font-weight: 500; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .social-handle { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--gray-500); }
  .social-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 4px;
    background: rgba(255,255,255,0.05);
    color: var(--gray-500);
    flex-shrink: 0;
    min-width: 60px;
    text-align: center;
  }

  /* CTA Card */
  .card-cta {
    grid-area: cta;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 20px;
    gap: 12px;
  }
  .cta-left { flex: 1; width: 100%; }
  .cta-headline { font-size: 15px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 4px; }
  .cta-sub { font-size: 12px; color: var(--gray-500); line-height: 1.4; }
  .cta-buttons { display: flex; gap: 8px; flex-shrink: 0; width: 100%; flex-direction: column; }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s ease;
    border: 1px solid var(--border);
    white-space: nowrap;
  }
  .cta-btn.primary { background: var(--white); color: var(--black); border-color: var(--white); }
  .cta-btn.primary:hover { background: var(--gray-100); transform: translateY(-1px); }
  .cta-btn.secondary { background: transparent; color: var(--gray-300); }
  .cta-btn.secondary:hover { background: var(--surface-hover); border-color: var(--gray-700); color: var(--white); transform: translateY(-1px); }

  /* Heatmap Card */
  .card-heatmap { grid-area: heatmap; min-height: 0; }
  .heatmap-wrapper { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 8px; }
  .heatmap-grid {
    display: grid;
    grid-template-columns: repeat(52, 1fr);
    grid-template-rows: repeat(7, 1fr);
    gap: 2px;
  }
  .heatmap-cell {
    aspect-ratio: 1;
    border-radius: 2px;
    background: #161b22;
    transition: transform 0.15s ease;
    cursor: default;
    position: relative;
  }
  .heatmap-cell:hover { transform: scale(1.8); z-index: 2; }
  .heatmap-cell.level-0 { background: #161b22; }
  .heatmap-cell.level-1 { background: #0e4429; }
  .heatmap-cell.level-2 { background: #006d32; }
  .heatmap-cell.level-3 { background: #26a641; }
  .heatmap-cell.level-4 { background: #39d353; }
  .heatmap-cell[data-tooltip]:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--gray-300);
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
  }
  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 3px;
    justify-content: flex-end;
  }
  .heatmap-level {
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }
  .heatmap-level.level-0 { background: #161b22; }
  .heatmap-level.level-1 { background: #0e4429; }
  .heatmap-level.level-2 { background: #006d32; }
  .heatmap-level.level-3 { background: #26a641; }
  .heatmap-level.level-4 { background: #39d353; }
  .heatmap-label { font-size: 9px; color: var(--gray-700); }
  .heatmap-total {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--gray-500);
    text-align: right;
    margin-top: 4px;
  }

  /* Pinned Repos Card */
  .card-pinned { grid-area: pinned; min-height: 0; }
  .pinned-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    flex: 1;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .pinned-grid::-webkit-scrollbar { display: none; }
  .pinned-loading {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-500);
    font-size: 12px;
  }
  .pinned-repo {
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px;
    text-decoration: none;
    color: var(--white);
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pinned-repo:hover { border-color: var(--border-hover); background: var(--surface-hover); }
  .pinned-repo-name {
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .pinned-repo-name svg { flex-shrink: 0; opacity: 0.5; }
  .pinned-repo-desc {
    font-size: 11px;
    color: var(--gray-500);
    line-height: 1.4;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pinned-repo-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    color: var(--gray-500);
  }
  .pinned-lang-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }

  /* Streak Widget */
  .card-streak { grid-area: streak; min-height: 0; }
  .streak-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
    justify-content: center;
  }
  .streak-stat {
    text-align: center;
    padding: 8px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .streak-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 24px;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }
  .streak-label {
    font-size: 9px;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
  }

  /* Timezone Card */
  .card-timezone { grid-area: timezone; min-height: 0; justify-content: center; align-items: center; text-align: center; }
  .tz-clock {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(24px, 2.5vw, 36px);
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 8px;
  }
  .tz-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
  }
  .tz-zone {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gray-300);
  }
  .tz-offset {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--gray-500);
    padding: 2px 8px;
    background: rgba(255,255,255,0.04);
    border-radius: 4px;
  }
  .tz-availability {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--gray-500);
  }
  .tz-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gray-700);
  }
  .tz-dot.available { background: #22c55e; animation: pulse 2s ease-in-out infinite; }
  .tz-dot.unavailable { background: var(--gray-500); }

  /* Interactive Terminal */
  .card-terminal { grid-area: terminal; min-height: 0; padding: 0; overflow: hidden; }
  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid var(--border);
  }
  .terminal-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--gray-500);
    margin-left: 8px;
  }
  .terminal-body {
    flex: 1;
    padding: 12px 14px;
    overflow-y: auto;
    scrollbar-width: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    line-height: 1.6;
    min-height: 100px;
