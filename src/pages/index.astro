---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Naman Gupta — Software Engineer & Astrophysics Enthusiast">
  <!-- Loading Screen -->
  <div class="loading-screen" id="loadingScreen">
    <div class="loading-content">
      <div class="loading-logo">NG</div>
      <div class="loading-bar"><div class="loading-fill"></div></div>
      <div class="loading-text">initializing...</div>
    </div>
  </div>

  <!-- Background Canvas -->
  <canvas id="bg-canvas"></canvas>

  <!-- Scroll Progress -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <!-- Custom Cursor -->
  <div class="cursor-dot" id="cursorDot"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- Background Switcher -->
  <div class="bg-switcher" id="bgSwitcher">
    <button class="bg-btn active" data-bg="particles" title="Particles">✦</button>
    <button class="bg-btn" data-bg="waves" title="Waves">〰</button>
    <button class="bg-btn" data-bg="stars" title="Stars">★</button>
    <button class="bg-btn" data-bg="geometry" title="Geometry">◇</button>
    <button class="bg-btn" data-bg="matrix" title="Matrix">⌨</button>
  </div>

  <!-- Project Preview Tooltip -->
  <div class="project-preview" id="projectPreview">
    <div class="project-preview-window">
      <div class="preview-titlebar">
        <span class="preview-dot r"></span>
        <span class="preview-dot y"></span>
        <span class="preview-dot g"></span>
        <span class="preview-url" id="previewUrl"></span>
      </div>
      <div class="preview-viewport">
        <iframe id="previewIframe" sandbox="allow-scripts allow-same-origin" loading="lazy"></iframe>
      </div>
    </div>
    <div class="preview-label">
      <span class="preview-dot green"></span>
      <span id="previewName">Loading preview...</span>
    </div>
  </div>

  <!-- Grid Layout -->
